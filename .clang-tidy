---
# The enabled families below are intentionally broad. The trailing block of
# disables turns off the checks that conflict with deliberate, codebase-wide
# idioms in this low-latency engine: brace-less single statements, dense arrays
# indexed by runtime values, trivially-copyable PODs left uninitialised on the
# hot path, fixed-size C arrays backing padding and storage, the slab arena's
# intrusive-freelist pointer punning, and the trailing-underscore convention
# for private members and methods. Disabling them keeps the remaining bugprone,
# analyzer, performance, and portability checks enforceable on every file.
Checks: >
  bugprone-*,
  cert-*,
  clang-analyzer-*,
  concurrency-*,
  cppcoreguidelines-*,
  hicpp-*,
  misc-*,
  modernize-*,
  performance-*,
  portability-*,
  readability-*,
  -bugprone-easily-swappable-parameters,
  -cppcoreguidelines-avoid-magic-numbers,
  -cppcoreguidelines-pro-bounds-array-to-pointer-decay,
  -cppcoreguidelines-pro-bounds-pointer-arithmetic,
  -cppcoreguidelines-pro-type-reinterpret-cast,
  -cppcoreguidelines-pro-type-union-access,
  -hicpp-no-array-decay,
  -hicpp-signed-bitwise,
  -misc-include-cleaner,
  -misc-non-private-member-variables-in-classes,
  -modernize-use-trailing-return-type,
  -readability-identifier-length,
  -readability-magic-numbers,
  -readability-named-parameter,
  -readability-redundant-access-specifiers,
  -readability-braces-around-statements,
  -hicpp-braces-around-statements,
  -readability-identifier-naming,
  -readability-function-cognitive-complexity,
  -readability-redundant-member-init,
  -readability-container-size-empty,
  -hicpp-named-parameter,
  -hicpp-member-init,
  -hicpp-avoid-c-arrays,
  -hicpp-vararg,
  -cppcoreguidelines-pro-bounds-constant-array-index,
  -cppcoreguidelines-pro-type-member-init,
  -cppcoreguidelines-avoid-c-arrays,
  -cppcoreguidelines-pro-type-vararg,
  -cppcoreguidelines-prefer-member-initializer,
  -modernize-avoid-c-arrays,
  -bugprone-sizeof-expression,
  -bugprone-multi-level-implicit-pointer-conversion,
  -cert-err33-c,
  -clang-analyzer-optin.performance.Padding

WarningsAsErrors: '*'

HeaderFilterRegex: '(include|src)/lob/.*\.(hpp|h)$'

FormatStyle: file

CheckOptions:
  - { key: cppcoreguidelines-avoid-non-const-global-variables.AllowInternalLinkage, value: true }
  - { key: performance-move-const-arg.CheckTriviallyCopyableMove, value: false }
  - { key: misc-include-cleaner.IgnoreHeaders,                    value: 'lob/.*' }
