# Normalise line endings + classify files for diff, merge, archive export, and
# GitHub Linguist. Conservative defaults: text=auto with eol=lf keeps Windows
# checkouts consistent without forcing CRLF on tracked content.

* text=auto eol=lf

### C / C++ source ###
*.c       text diff=cpp
*.cc      text diff=cpp
*.cpp     text diff=cpp
*.cxx     text diff=cpp
*.h       text diff=cpp
*.hh      text diff=cpp
*.hpp     text diff=cpp
*.hxx     text diff=cpp
*.tpp     text diff=cpp
*.ipp     text diff=cpp
*.inl     text diff=cpp
*.cu      text diff=cpp
*.cuh     text diff=cpp

### Build + tooling ###
CMakeLists.txt   text diff=cmake
*.cmake          text diff=cmake
*.cmake.in       text diff=cmake
CMakePresets.json text
*.json            text
*.yml             text
*.yaml            text
*.toml            text
*.ini             text
*.cfg             text
*.conf            text
*.in              text
Makefile         text
Dockerfile       text
*.dockerignore   text

### Python ###
*.py    text diff=python
*.pyi   text diff=python

### Shell + scripts ###
*.sh    text eol=lf
*.bash  text eol=lf
*.zsh   text eol=lf
*.fish  text eol=lf
*.bat   text eol=crlf
*.cmd   text eol=crlf
*.ps1   text eol=crlf

### Docs ###
*.md      text diff=markdown
*.rst     text
*.txt     text
LICENSE   text
AUTHORS   text
README    text
CHANGELOG text
NOTICE    text

### Patches ###
*.patch   text eol=lf
*.diff    text eol=lf

### Linguist hints ###
include/**       linguist-language=C++
src/**           linguist-language=C++
tests/**.cpp     linguist-language=C++
bench/**.cpp     linguist-language=C++
scripts/**.py    linguist-language=Python
docs/**          linguist-documentation
cmake/**         linguist-detectable=true linguist-language=CMake
*.cmake          linguist-detectable=true linguist-language=CMake
vcpkg.json       linguist-generated=false
vcpkg_installed/ linguist-vendored
_deps/           linguist-vendored
build/           linguist-generated
build-*/         linguist-generated
docs/_build/     linguist-generated

